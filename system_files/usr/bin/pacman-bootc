#!/bin/bash

if [[ $EUID -ne 0 ]] && [[ "$1" != "--help" ]] && [[ "$1" != "" ]] ; then
   echo "Error: This command must be executed as the root user!" >&2
   exit 1
fi

CMD_DIR="/usr/lib/pacman-bootc"

case "$1" in
    "update")
        $CMD_DIR/pacman-bootc-update
        ;;
    "upgrade")
        $CMD_DIR/pacman-bootc-update
        ;;
    "rollback")
        /usr/bin/bootc rollback
        ;;
    "reset")
        $CMD_DIR/pacman-bootc-reset
        ;;
    "switch")
        $CMD_DIR/pacman-bootc-reset
        /usr/bin/bootc switch "$2"
        ;;
    "usroverlay")
        /usr/bin/bootc usroverlay
        systemd-sysext unmerge
        ;;
    "-S")
        if [[ "$2" == "" ]]; then
            $CMD_DIR/pacman-bootc-install
        else
            $CMD_DIR/pacman-bootc-install "$2"
        fi
        ;;
    "install")
        if [[ "$2" == "" ]]; then
            $CMD_DIR/pacman-bootc-install
        else
            $CMD_DIR/pacman-bootc-install "$2"
        fi
        ;;
    "-R")
        if [[ "$2" == "" ]]; then
            $CMD_DIR/pacman-bootc-remove
        else
            $CMD_DIR/pacman-bootc-remove "$2"
        fi
            ;;
    "remove")
        if [[ "$2" == "" ]]; then
            $CMD_DIR/pacman-bootc-remove
        else
            $CMD_DIR/pacman-bootc-remove "$2"
        fi
        ;;
    "list")
        $CMD_DIR/pacman-bootc-list
        ;;
    "status")
        /usr/bin/bootc status
        echo ""
        echo "To check for installed packages, run pacman-bootc list."
        ;;
    "--help")
        echo "Wrapper for bootc and sysexts"
        echo ""
        echo "Avaible commands:"
        echo "update, rollback, reset, switch, usroverlay, install (-S), remove (-R), list, status"
        ;;
    "")
        echo "Wrapper for bootc and sysexts"
        echo ""
        echo "Avaible commands:"
        echo "update, rollback, reset, switch, usroverlay, install (-S), remove (-R), list, status"
        ;;
esac
