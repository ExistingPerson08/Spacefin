#!/bin/bash

if [[ $EUID -ne 0 && ! "$1" =~ ^(info|-Qi|--help|)$ ]]; then
   echo "Error: This command must be executed as root!"
   exit 1
fi

CMD_DIR="/usr/lib/pacman-bootc"

COMMAND="$1"
shift

case "$COMMAND" in
    "update"|"upgrade")
        bootc update
        $CMD_DIR/pacman-bootc-update
        ;;
    "rollback")
        /usr/bin/bootc rollback
        ;;
    "reset")
        $CMD_DIR/pacman-bootc-reset
        ;;
    "switch")
        $CMD_DIR/pacman-bootc-reset
        /usr/bin/bootc switch "$1"
        ;;
    "switch-stream")
        case "$1" in
            "stable")
                $CMD_DIR/pacman-bootc-update
                /usr/bin/bootc switch ghcr.io/existingperson/spacefin:stable
                ;;
            "latest")
                $CMD_DIR/pacman-bootc-update
                /usr/bin/bootc switch ghcr.io/existingperson/spacefin:latest
                ;;
            ""|*)
                echo "Choose one of these streams:"
                echo "stable     Stable stream (build weekly)"
                echo "latest     Always latest features and packages (build daily and on-demand)"
                echo ""
                echo "Changing streams will also update sysexts to prevent partial updates"
                ;;
        esac
        ;;
    "usroverlay")
        case "$1" in
            "")
                /usr/bin/bootc usroverlay
                ;;
            "--force")
                /usr/bin/bootc usroverlay
                systemd-sysext unmerge
                ;;
            *)
                echo "Unknown option"
                echo "Options:"
                echo "--force     Also unmerge sysexts"
                ;;
        esac
        ;;
    "install"|"-S")
        $CMD_DIR/pacman-bootc-install "$@"
        ;;
    "remove"|"-R")
        $CMD_DIR/pacman-bootc-remove "$@"
        ;;
    "build")
        $CMD_DIR/pacman-bootc-build "$@"
        ;;
    "list")
        $CMD_DIR/pacman-bootc-list
        ;;
    "info"|"-Qi")
        /usr/bin/pacman -Qi "$@"
        ;;
    "status")
        /usr/bin/bootc status
        echo ""
        echo "To check for installed packages, run pacman-bootc list."
        ;;
    "update-sysexts")
        $CMD_DIR/pacman-bootc-update
        ;;
    "disable-sysexts")
        $CMD_DIR/pacman-bootc-reset
        systemd-sysext unmerge
        systemctl disable --now systemd-sysext
        ;;
    "enable-sysexts")
        systemctl enable --now systemd-sysext
        systemd-sysext merge
        ;;
    ""|"--help")
        echo "Wrapper for bootc and sysexts"
        echo ""
        echo "Available commands:"
        echo "update, rollback, reset, switch, switch-stream, usroverlay, install (-S), remove (-R), build list, info (-Q), status, disable/enable-sysexts"
        ;;
    *)
        echo "Error: Unknown command '$COMMAND'"
        exit 1
        ;;
esac
