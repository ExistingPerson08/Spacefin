#!/bin/bash

if [[ $EUID -ne 0 && ! "$1" =~ ^(info|-Qi|--help|)$ ]]; then
   echo "Error: This command must be executed as the root user!"
   exit 1
fi

CMD_DIR="/usr/lib/pacman-bootc"

COMMAND="$1"
shift

case "$COMMAND" in
    "update"|"upgrade")
        $CMD_DIR/pacman-bootc-update
        ;;
    "rollback")
        /usr/bin/bootc rollback
        ;;
    "reset")
        $CMD_DIR/pacman-bootc-reset
        ;;
    "switch")
        $CMD_DIR/pacman-bootc-reset
        /usr/bin/bootc switch "$1"
        ;;
    "usroverlay")
        /usr/bin/bootc usroverlay
        systemd-sysext unmerge
        ;;
    "install"|"-S")
        $CMD_DIR/pacman-bootc-install "$@"
        ;;
    "remove"|"-R")
        $CMD_DIR/pacman-bootc-remove "$@"
        ;;
    "list")
        $CMD_DIR/pacman-bootc-list
        ;;
    "info"|"-Qi")
        /usr/bin/pacman -Qi "$@"
        ;;
    "status")
        /usr/bin/bootc status
        echo ""
        echo "To check for installed packages, run pacman-bootc list."
        ;;
    "disable-sysext")
        $CMD_DIR/pacman-bootc-reset
        systemd-sysext unmerge
        systemctl disable --now systemd-sysext
        ;;
    "enable-sysext")
        systemctl enable --now systemd-sysext
        systemd-sysext merge
        ;;
    ""|"--help")
        echo "Wrapper for bootc and sysexts"
        echo ""
        echo "Available commands:"
        echo "update, rollback, reset, switch, usroverlay, install (-S), remove (-R), list, info (-Q), status, disable/enable-sysext"
        ;;
    *)
        echo "Error: Unknown command '$COMMAND'"
        exit 1
        ;;
esac
